# EditorConfig — https://editorconfig.org
root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# C# files
[*.cs]
indent_size = 4

# C# project and solution files
[*.{csproj,sln,props,targets}]
indent_size = 2

# Dart files
[*.dart]
indent_size = 2

# YAML files (pubspec, analysis_options, CI configs)
[*.{yaml,yml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Dockerfiles and shell scripts
[{Dockerfile,*.sh}]
indent_size = 2
