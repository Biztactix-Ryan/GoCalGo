# =============================================================================
# GoCalGo Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gocalgo
POSTGRES_USER=gocalgo
POSTGRES_PASSWORD=          # Required — do not commit real passwords

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Firebase
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=        # Required — your Firebase project ID (e.g. gocalgo)
FIREBASE_CREDENTIALS_JSON=  # Required — path to service-account JSON key file (e.g. firebase-service-account.json)

# -----------------------------------------------------------------------------
# ScrapedDuck API (Pokemon GO data source)
# -----------------------------------------------------------------------------
SCRAPEDDUCK_BASE_URL=https://pokemon-go-api.github.io/pokemon-go-api
SCRAPEDDUCK_CACHE_EXPIRATION_MINUTES=30

# -----------------------------------------------------------------------------
# Flutter / Mobile App
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:5000  # Backend API URL used at build time

# -----------------------------------------------------------------------------
# Android Signing
# -----------------------------------------------------------------------------
ANDROID_KEYSTORE_PATH=       # Required for release — path to .jks keystore file
ANDROID_KEYSTORE_PASSWORD=   # Required for release — keystore password
ANDROID_KEY_ALIAS=           # Required for release — key alias within the keystore
ANDROID_KEY_PASSWORD=        # Required for release — key password

# -----------------------------------------------------------------------------
# iOS Signing
# -----------------------------------------------------------------------------
IOS_PROVISIONING_PROFILE=    # Required for release — provisioning profile name or UUID
IOS_CODE_SIGN_IDENTITY=      # Required for release — e.g. "Apple Distribution: Team Name (XXXXXXXXXX)"
IOS_TEAM_ID=                 # Required for release — Apple Developer Team ID

# -----------------------------------------------------------------------------
# ASP.NET Core
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
